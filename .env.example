# Database
export DB_PASSWORD=postgres
export DB_SSLMODE=disable

# Teller (get from https://teller.io/settings)
export TELLER_APP_ID=your_app_id
export TELLER_ENV=sandbox
# Certificate paths (required for production/development, optional for sandbox)
export TELLER_CERT_PATH=./teller/certificate.pem
export TELLER_KEY_PATH=./teller/private_key.pem

# Encryption key (32-byte hex string for AES-256)
# Generate with: openssl rand -hex 32
export ENCRYPTION_KEY=your_64_char_hex_string

# App password (optional — if unset, auth is disabled)
# export APP_PASSWORD=your_password
